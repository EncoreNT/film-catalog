generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum MovieStatus {
  DRAFT
  CATALOG
  EXCLUDED
}

enum ReleaseBuildStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
}

enum ReleaseBuildTrackKind {
  VIDEO
  AUDIO
  SUBTITLE
}

enum ReleaseBuildAudioMode {
  COPY
  TRANSCODE
}

enum ReleaseBuildChannelTarget {
  STEREO
  UP_TO_51
}

/** Named external drive; null externalStorageId on Release means local disk. */
model ExternalStorage {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  path      String?
  createdAt DateTime @default(now())

  releases Release[]
  builds   ReleaseBuild[]
}

model Movie {
  id          Int         @id @default(autoincrement())
  slug        String      @unique
  title       String
  year        Int?
  description String?
  matchKey    String?
  status      MovieStatus @default(DRAFT)
  coverPath   String?
  rating      Int?
  watchedAt   DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  movieGenres MovieGenre[]
  slots       FranchiseSlot[]
  releases    Release[]
  builds      ReleaseBuild[]

  @@index([status])
  @@index([matchKey])
  @@index([rating])
  @@index([watchedAt])
}

model Release {
  id                  Int         @id @default(autoincrement())
  movieId             Int
  externalStorageId   Int?
  filePath            String?     @unique
  fileSize        Int?
  fileMtime       DateTime?
  fileHash        String?
  releaseType     String?
  version         String      @default("theatrical")
  durationSeconds Int?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  movie            Movie             @relation(fields: [movieId], references: [id], onDelete: Cascade)
  externalStorage  ExternalStorage?  @relation(fields: [externalStorageId], references: [id], onDelete: SetNull)
  videoTrack     VideoTrack?
  audioTracks    AudioTrack[]
  subtitleTracks SubtitleTrack[]
  buildSources   ReleaseBuildSource[]
  buildTracks    ReleaseBuildTrack[]
  outputBuilds   ReleaseBuild[]       @relation("BuildOutputRelease")

  @@index([movieId])
  @@index([fileHash])
  @@index([externalStorageId])
  @@index([releaseType])
  @@index([version])
  @@index([durationSeconds])
}

model Genre {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  movieGenres MovieGenre[]
  createdAt   DateTime     @default(now())

  @@index([name])
}

model MovieGenre {
  movieId   Int
  genreId   Int
  sortOrder Int    @default(0)
  movie     Movie  @relation(fields: [movieId], references: [id], onDelete: Cascade)
  genre     Genre  @relation(fields: [genreId], references: [id], onDelete: Cascade)

  @@id([movieId, genreId])
  @@index([movieId, sortOrder])
}

model VideoTrack {
  id              Int      @id @default(autoincrement())
  releaseId       Int      @unique
  streamIndex     Int
  width           Int?
  height          Int?
  resolutionLabel String?
  codec           String?
  hdr             String?
  fps             String?
  bitrate         Int?
  release         Release  @relation(fields: [releaseId], references: [id], onDelete: Cascade)

  @@index([resolutionLabel])
}

model AudioTrack {
  id              Int      @id @default(autoincrement())
  releaseId       Int
  streamIndex     Int
  codec           String?
  profile         String?
  channels        Int?
  channelLayout   String?
  bitrate         Int?
  language        String?
  title           String?
  translationType String?
  isDefault       Boolean  @default(false)
  release         Release  @relation(fields: [releaseId], references: [id], onDelete: Cascade)

  @@index([language])
  @@index([channelLayout])
  @@index([translationType])
}

model SubtitleTrack {
  id          Int      @id @default(autoincrement())
  releaseId   Int
  streamIndex Int
  codec       String?
  codecLabel  String?
  language    String?
  title       String?
  isDefault   Boolean  @default(false)
  forced      Boolean  @default(false)
  release     Release  @relation(fields: [releaseId], references: [id], onDelete: Cascade)

  @@index([language])
}

model Setting {
  key   String @id
  value String
}

model ReleaseBuild {
  id                   Int                @id @default(autoincrement())
  movieId              Int
  status               ReleaseBuildStatus @default(QUEUED)
  phase                String?
  progressPercent      Float?
  progressMessage      String?
  errorMessage         String?
  cancelRequested      Boolean            @default(false)
  heartbeatAt          DateTime?
  startedAt            DateTime?
  finishedAt           DateTime?
  outputPath           String
  outputReleaseType    String?
  outputVersion        String             @default("theatrical")
  outputReleaseId      Int?
  externalStorageId    Int?
  acknowledgedWarnings String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  movie           Movie              @relation(fields: [movieId], references: [id], onDelete: Restrict)
  outputRelease   Release?           @relation("BuildOutputRelease", fields: [outputReleaseId], references: [id], onDelete: SetNull)
  externalStorage ExternalStorage?   @relation(fields: [externalStorageId], references: [id], onDelete: SetNull)
  sources         ReleaseBuildSource[]
  tracks          ReleaseBuildTrack[]

  @@index([movieId])
  @@index([status])
  @@index([outputPath])
  @@index([createdAt])
}

model ReleaseBuildSource {
  id              Int      @id @default(autoincrement())
  buildId         Int
  releaseId       Int?
  filePath        String
  durationSeconds Float?
  role            String
  createdAt       DateTime @default(now())

  build   ReleaseBuild @relation(fields: [buildId], references: [id], onDelete: Cascade)
  release Release?     @relation(fields: [releaseId], references: [id], onDelete: SetNull)

  @@index([buildId])
  @@index([releaseId])
}

model ReleaseBuildTrack {
  id                Int                        @id @default(autoincrement())
  buildId           Int
  sortOrder         Int
  kind              ReleaseBuildTrackKind
  sourceReleaseId   Int?
  sourceStreamIndex Int
  sourceFilePath    String
  sourceTrackLabel  String?
  audioMode         ReleaseBuildAudioMode?
  transcodeCodec    String?
  transcodeBitrate  Int?
  channelTarget     ReleaseBuildChannelTarget?
  offsetMs          Int                        @default(0)
  isDefault         Boolean                    @default(false)
  forced            Boolean                    @default(false)
  createdAt         DateTime                   @default(now())

  build         ReleaseBuild @relation(fields: [buildId], references: [id], onDelete: Cascade)
  sourceRelease Release?     @relation(fields: [sourceReleaseId], references: [id], onDelete: SetNull)

  @@index([buildId, sortOrder])
  @@index([sourceReleaseId])
}

model Franchise {
  id          Int             @id @default(autoincrement())
  slug        String          @unique
  name        String
  description String?
  coverPath   String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  slots       FranchiseSlot[]

  @@index([name])
}

model FranchiseSlot {
  id          Int       @id @default(autoincrement())
  franchiseId Int
  movieId     Int?
  storyOrder  Int
  titleHint   String?
  yearHint    Int?
  /** Empty slot explicitly marked as unreleased (no year required). */
  isAnnounced Boolean   @default(false)
  createdAt   DateTime  @default(now())
  franchise   Franchise @relation(fields: [franchiseId], references: [id], onDelete: Cascade)
  movie       Movie?    @relation(fields: [movieId], references: [id], onDelete: SetNull)

  @@unique([franchiseId, movieId])
  @@index([franchiseId, storyOrder])
  @@index([franchiseId])
}
