{
  "name": "film-catalog",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n web,worker -c cyan,magenta \"npm run dev:web\" \"npm run worker:builds\"",
    "dev:web": "NEXT_TELEMETRY_DISABLED=1 next dev",
    "worker:builds": "tsx scripts/release-build-worker.ts",
    "build": "NEXT_TELEMETRY_DISABLED=1 next build",
    "start": "NEXT_TELEMETRY_DISABLED=1 next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "postinstall": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:backfill-match-keys": "tsx scripts/backfill-match-keys.ts",
    "db:backfill-slugs": "tsx scripts/backfill-movie-slugs.ts",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "better-sqlite3": "^12.11.1",
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.2",
    "execa": "^9.6.1",
    "lucide-react": "^1.21.0",
    "motion": "^12.41.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.5",
    "typescript": "^5",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "@hono/node-server": "1.19.13",
    "postcss": "8.5.15",
    "npm-run-path": "5.3.0"
  }
}
